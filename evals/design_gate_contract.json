{
  "schema_version": 1,
  "source": "references/design-gate-cards.md",
  "template": "templates/method_gate.md",
  "minimum_design_count": 9,
  "minimum_guardrail_count": 10,
  "required_template_markers": [
    "Design Gate Card",
    "Design card used:",
    "Hard Flags",
    "Claim Downgrade",
    "workflow_state.json.method_gate.required_artifacts",
