    "workflow_state.json.evidence_governance.claim_strength"
  ],
  "design_cards": [
    {
      "id": "did_event_study",
      "heading": "DiD / Event Study / Staggered Adoption",
      "method_gate_label": "DiD",
      "minimum_required_artifacts": 7,
      "required_items": [
        "Adoption/cohort table",
        "Pre-period coverage",
        "Event-study plot/table",
        "Staggered estimator",
        "Naive TWFE contrast",
        "Anticipation/placebo timing",
        "Sensitivity"
      ],
      "claim_levels": [
        "causal",
        "qualified_causal",
        "descriptive"
      ]
    },
    {
      "id": "iv_2sls_late",
      "heading": "IV / 2SLS / LATE",
      "method_gate_label": "IV",
      "minimum_required_artifacts": 7,
      "required_items": [
        "First stage",
